              <calculation class='tableau' formula='2023' />
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.0he3vko0nnl7wm17tldau04q447z'>
            <column aggregation='CountD' caption='PY Customers  ' datatype='string' default-role='measure' default-type='quantitative' name='[CY Customers  (copy)_0599806087229442]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF YEAR([Order Date])=[Parameters].[Parameter 0931308315729924]-1 THEN [Customer ID]&#13;&#10;END' />
            </column>
            <column aggregation='CountD' caption='CY Customers ' datatype='string' default-role='measure' default-type='quantitative' name='[Calculation_0599806086692864]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF YEAR([Order Date])=[Parameters].[Parameter 0931308315729924] THEN [Customer ID]&#13;&#10;END' />
            </column>
            <column caption='% Diff Customers ' datatype='real' default-format='p0.0%' name='[Calculation_0599806087516163]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='(COUNTD([Calculation_0599806086692864]) - COUNTD([CY Customers  (copy)_0599806087229442])) / COUNTD([CY Customers  (copy)_0599806087229442])' />
            </column>
            <column caption='Min/Max Customers' datatype='integer' name='[Calculation_0599806100258823]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF COUNTD([Calculation_0599806086692864]) = WINDOW_MAX(COUNTD([Calculation_0599806086692864]))&#13;&#10;THEN COUNTD([Calculation_0599806086692864])&#13;&#10;ELSEIF COUNTD([Calculation_0599806086692864]) = WINDOW_MIN(COUNTD([Calculation_0599806086692864]))&#13;&#10;THEN COUNTD([Calculation_0599806086692864])&#13;&#10;END'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column aggregation='Sum' caption='Current Year' datatype='integer' default-format='n0;-0' name='[Calculation_0931308336435209]' role='dimension' type='ordinal'>
              <calculation class='tableau' formula='[Parameters].[Parameter 0931308315729924]' />
            </column>
            <column caption='{[% Diff Customers ]}' datatype='real' name='[Calculation_1313664667111426]' role='measure' type='quantitative' user:unnamed='KPI Customer'>
              <calculation class='tableau' formula='{[Calculation_0599806087516163]}' />
            </column>
            <column caption='{COUNTD([CY Customers ])}' datatype='integer' name='[Calculation_1313664668876804]' role='measure' type='quantitative' user:unnamed='KPI Customer'>
              <calculation class='tableau' formula='{COUNTD([Calculation_0599806086692864])}' />
            </column>
            <column datatype='string' name='[Category]' role='dimension' type='nominal' />
            <column datatype='string' name='[City]' role='dimension' semantic-role='[City].[Name]' type='nominal' />
            <column aggregation='Sum' caption='Previous Year' datatype='integer' default-format='n0;-0' name='[Current Year (copy)_0931308336656394]' role='dimension' type='ordinal'>
              <calculation class='tableau' formula='[Parameters].[Parameter 0931308315729924]-1' />
            </column>
            <column aggregation='CountD' datatype='string' default-role='measure' default-type='quantitative' name='[Customer ID]' role='dimension' type='nominal' />
            <column datatype='date' name='[Order Date]' role='dimension' type='ordinal' />
            <column datatype='string' name='[Region]' role='dimension' semantic-role='[Country].[Name]' type='nominal' />
