              <calculation class='tableau' formula='SUM([Calculation_0931308314341376]) / COUNTD([Calculation_0599806086692864])' />
            </column>
            <column caption='% Diff Sales per Customers' datatype='real' default-format='p0.0%' name='[Calculation_0599806099464198]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF SUM([CY Sales  (copy)_0931308315107330]) / COUNTD([CY Customers  (copy)_0599806087229442]) &lt;&gt; 0 THEN&#13;&#10;    (&#13;&#10;        SUM([Calculation_0931308314341376]) / COUNTD([Calculation_0599806086692864])&#13;&#10;        -&#13;&#10;        SUM([CY Sales  (copy)_0931308315107330]) / COUNTD([CY Sales  (copy)_0931308315107330])&#13;&#10;    )&#13;&#10;    /&#13;&#10;    (&#13;&#10;        SUM([CY Sales  (copy)_0931308315107330]) / COUNTD([CY Customers  (copy)_0599806087229442])&#13;&#10;    )&#13;&#10;END' />
            </column>
            <column caption='CY Sales ' datatype='real' default-format='n&quot;$&quot;#,##0,K;-&quot;$&quot;#,##0,K' name='[Calculation_0931308314341376]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF YEAR([Order Date])=[Parameters].[Parameter 0931308315729924] THEN [Sales]&#13;&#10;END' />
            </column>
            <column caption='Sales per Customer' datatype='real' name='[Calculation_0997005351968768]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([Sales])/COUNTD([Customer ID])' />
            </column>
