              <calculation class='tableau' formula='IF SUM([Calculation_1173200957050880])=WINDOW_MAX(SUM([Calculation_1173200957050880]))&#13;&#10;THEN SUM([Calculation_1173200957050880])&#13;&#10;ELSEIF SUM([Calculation_1173200957050880])=WINDOW_MIN(SUM([Calculation_1173200957050880]))&#13;&#10;THEN SUM([Calculation_1173200957050880])&#13;&#10;END'>
